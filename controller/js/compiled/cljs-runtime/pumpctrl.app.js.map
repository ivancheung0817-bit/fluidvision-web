(ns pumpctrl.app
  (:require [uix.core :as uix :refer [defui $]]
            [uix.dom]
            [pumpctrl.bluetooth :as bt]
            [pumpctrl.icons :as icons]
            [pumpctrl.style :as s :refer [cx]]))

(def safe-max-volume 10.0)

(defn clamp-target-volume [v disable-restriction?]
  (cond
    (js/isNaN v) 0.0
    (neg? v) 0.0
    disable-restriction? v
    :else (min v safe-max-volume)))

(defui app []
  (let [char-ref (uix/use-ref nil)
        bluetooth-supported? (bt/bluetooth-supported?)
        [state set-state!] (uix/use-state {:current-volume 0.0
                                           :target-volume 10.0
                                           :connected? false
                                           :connecting? false
                                           :instant-mode? false
                                           :disable-restriction? false})

        {:keys [current-volume target-volume connected? connecting? instant-mode? disable-restriction?]} state

        dispatch-pump! (fn [st]
                         (let [delta (- (:target-volume st) (:current-volume st))]
                           (when-not (zero? delta)
                             (let [duration-ms (Math/round (* (Math/abs delta) 1000))
                                   command (if (pos? delta) "P" "D")]
                               (bt/send-command! char-ref command duration-ms)
                               (set-state! assoc :current-volume (:target-volume st))))))

        update-target! (fn [^js e]
                         (let [raw-val (js/parseFloat (.. e -target -value))
                               parsed-val (if (js/isNaN raw-val) target-volume raw-val)
                               clamped-val (clamp-target-volume parsed-val disable-restriction?)
                               new-state (assoc state :target-volume clamped-val)]
                           (set-state! new-state)
                           (when instant-mode?
                             (dispatch-pump! new-state))))

        handle-submit! (fn [^js e]
                         (.preventDefault e)
                         (dispatch-pump! state))

        toggle-disable-restriction! (fn [^js e]
                                      (let [enabled? (.. e -target -checked)
                                            adjusted-target (if enabled?
                                                              target-volume
                                                              (min target-volume safe-max-volume))]
                                        (set-state! assoc
                                                    :disable-restriction enabled?
                                                    :target-volume adjusted-target)))]

    ($ :div {:class s/app-container}

       ;; Header section
       ($ :div {:class s/header-container}
          ($ :div {:class s/header-left-col}
             ($ :div {:class s/header-icon-bg}
                ($ icons/header-icon))
             ($ :h2 {:class s/header-title}
                "Liquid Controller"))

          ;; Status Indicator
          ($ :div {:class s/status-container}
             ($ :div {:class (cx s/status-dot-base
                                 (if connected? s/status-dot-online s/status-dot-offline))})
             ($ :span {:class s/status-text}
                (if connected? "Online" "Offline"))))

       ;; Connection Overlay
       ($ :div {:class (if connected? s/overlay-hidden s/overlay-base)}
          ($ :div {:class s/overlay-icon-bg}
             ($ icons/bluetooth-icon))
          ($ :h3 {:class s/overlay-title}
             (if bluetooth-supported?
               "Hardware Disconnected"
               "Bluetooth Unsupported"))
          ($ :p {:class s/overlay-desc}
             (if bluetooth-supported?
               "Please connect your Bluetooth Pump Hardware to continue."
               "This browser does not support Web Bluetooth. Please use a compatible browser (for example: Google Chrome or Edge)."))
          ($ :button {:class (cx s/connect-btn-base
                                 (if (and bluetooth-supported? (not connecting?))
                                   s/connect-btn-active
                                   s/connect-btn-disabled))
                      :disabled (or (not bluetooth-supported?) connecting?)
                      :on-click #(when bluetooth-supported?
                                   (set-state! assoc :connecting? true)
                                   (bt/connect! char-ref (fn [status]
                                                           (set-state! assoc :connected? status :connecting? false))))}
             (if connecting?
               ($ :div {:class s/connect-spinner-container}
                  ($ icons/spinner-icon)
                  ($ :span "Connecting..."))
               (if bluetooth-supported?
                 "Connect Device"
                 "Bluetooth Not Supported"))))

       ;; Main Controls Wrapped in a Form
       ($ :form {:class (cx s/form-base
                            (when-not connected? s/form-disabled))
                 :on-submit handle-submit!}
          ($ :div {:class s/form-spacing}

             ;; Value Display Card
             ($ :div {:class s/card-base}
                ($ :div {:class s/card-header}
                   ($ :span {:class s/card-title} "Target Volume")
                   ($ :span {:class s/card-subtitle}
                      "Current: " ($ :span {:class s/card-subtitle-val} current-volume) " units"))
                ($ :div {:class s/input-container}
                   ($ :input {:type "number"
                              :value target-volume
                              :min "0"
                              :max (when-not disable-restriction? safe-max-volume)
                              :step "0.1"
                              :on-change update-target!
                              :class s/target-input
                              :style {:MozAppearance "textfield"}})
                   ($ :span {:class s/target-unit} "units")))

             ;; Slider Section
             ($ :div {:class s/slider-section}
                ($ :input {:type "range"
                           :min "0"
                           :max "10"
                           :step "0.1"
                           :value (min target-volume safe-max-volume)
                           :disabled disable-restriction?
                           :on-change update-target!
                           :class (cx s/slider-base
                                      (if disable-restriction?
                                        s/slider-disabled
                                        s/slider-active))})
                ($ :div {:class s/slider-labels}
                   ($ :span "0")
                   ($ :span "10")))

             ;; Toggle Section 
             ($ :div {:class s/toggle-section}

                ;; Instant Dispatch
                ($ :div {:class s/toggle-row}
                   ($ :div {:class s/toggle-text-col}
                      ($ :span {:class s/toggle-title} "Instant Dispatch")
                      ($ :span {:class s/toggle-desc} "Apply changes immediately"))
                   ($ :label {:class s/toggle-label}
                      ($ :input {:type "checkbox"
                                 :checked instant-mode?
                                 :on-change #(set-state! assoc :instant-mode (.. ^js % -target -checked))
                                 :class s/toggle-input})
                      ($ :div {:class (cx s/toggle-slider-base s/toggle-slider-blue)})))

                ;; Disable Restriction
                ($ :div {:class s/toggle-row}
                   ($ :div {:class s/restriction-row-left}
                      ($ :div {:class s/toggle-text-col}
                         ($ :span {:class s/toggle-title} "Disable Restriction")
                         ($ :span {:class s/toggle-desc} "Removes the 10-unit cap and disables the slider"))
                      ($ :div {:class s/warning-container}
                         ($ :div {:class s/warning-icon-base} "!")
                         ($ :div {:class s/warning-tooltip}
                            "Warning: disabling the restriction allows unrestricted pump durations. Use only if you fully understand the risk of over-dispensing or hardware damage.")))
                   ($ :label {:class s/toggle-label}
                      ($ :input {:type "checkbox"
                                 :checked disable-restriction?
                                 :on-change toggle-disable-restriction!
                                 :class s/toggle-input})
                      ($ :div {:class (cx s/toggle-slider-base s/toggle-slider-red)}))))

             ;; Action Buttons Section
             ($ :div {:class s/card-base}
                ($ :div {:class s/action-grid}
                   ($ :button {:type "submit"
                               :class s/dispatch-btn}
                      ($ icons/dispatch-icon)
                      ($ :span "Dispatch"))
                   ($ :button {:type "button"
                               :on-click #(bt/send-command! char-ref "H" 0)
                               :class s/halt-btn}
                      ($ icons/halt-icon)
                      ($ :span "HALT")))))))))

(defonce root (uix.dom/create-root (js/document.getElementById "root")))

(defn ^:export init []
  (uix.dom/render-root ($ app) root))
