(ns pumpctrl.bluetooth)

(def service-uuid "4fafc201-1fb5-459e-8fcc-c5c9c331914b")
(def char-uuid "beb5483e-36e1-4688-b7f5-ea07361b26a8")

(defn bluetooth-supported? []
  (boolean (.-bluetooth js/navigator)))

(defn connect! [char-ref on-connected]
  (if-not (bluetooth-supported?)
    (do
      (js/console.error "Web Bluetooth is not supported")
      (on-connected false))
    (-> (.requestDevice js/navigator.bluetooth
                        #js {:acceptAllDevices true
                             :optionalServices #js [service-uuid]})
        (.then (fn [^js device]
                 (.. device -gatt connect)))
        (.then (fn [^js server]
                 (.getPrimaryService server service-uuid)))
        (.then (fn [^js service]
                 (.getCharacteristic service char-uuid)))
        (.then (fn [characteristic]
                 (reset! char-ref characteristic)
                 (on-connected true)))
        (.catch (fn [error]
                  (js/console.error "Bluetooth Connection Failed" error)
                  (on-connected false))))))

(defn send-command! [char-ref cmd value]
  (when-let [^js characteristic @char-ref]
    (let [packet (str "!" cmd ":" value "#")
          encoder (js/TextEncoder.)
          encoded (.encode encoder packet)]
      (.writeValue characteristic encoded)
      (js/console.log "Sent:" packet))))
